# Voyage AI 3D - Environment Variables
# Copy this file to .env.local and fill in your keys.

# OpenAI API Key (REQUIRED for LLM extraction & enrichment)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouteService API Key (RECOMMENDED for accurate road routing)
# Falls back to OSRM -> Haversine when absent.
# Get your FREE key at: https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here

# API Ninjas Key (OPTIONAL - for airport lookups, 30,000+ airports)
# Get your key at: https://api-ninjas.com/api/airports
API_NINJAS_KEY=your_api_ninjas_key_here
